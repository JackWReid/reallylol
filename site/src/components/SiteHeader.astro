---
interface Props {
  currentPage?: number;
  lastPage?: number;
}

const { currentPage, lastPage } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { label: "Blog", href: "/blog/" },
  { label: "Notes", href: "/notes/" },
  { label: "Photos", href: "/photos/" },
  { label: "Library", href: "/books/read" },
  { label: "Links", href: "/links/saved" },
];

function isActive(href: string): boolean {
  if (href === "/books/read") return pathname.startsWith("/books/") || pathname.startsWith("/films/");
  if (href === "/links/saved") return pathname.startsWith("/links/");
  if (href === "/blog/") return pathname.startsWith("/blog/") || pathname.startsWith("/post/");
  return pathname.startsWith(href);
}

const showPageIndicator = currentPage && lastPage && lastPage > 1;
---
<header class="site-header">
  <div class="site-header__left">
    <a href="/" class="site-header__logo">really.lol</a>
    {showPageIndicator && (
      <span class="site-header__page">p. {currentPage}/{lastPage}</span>
    )}
  </div>
  <nav class="site-header__nav" aria-label="Main navigation">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={["site-header__link", { "site-header__link--active": isActive(item.href) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>
