---
import Base from "../../layouts/Base.astro";
import booksData from "../../data/books-reading.json";

interface BookRow { title: string; author: string; date_updated: string; }
const books = (booksData as BookRow[]).sort((a, b) => a.title.localeCompare(b.title));
---

<Base title="Library" section="library">
  <main>
    <div class="library">
      <div class="section-tabs">
        <a href="/books/read">Read</a>
        <a href="/books/reading" class="active">Reading</a>
        <a href="/books/toread">To Read</a>
        <span class="tab-divider" />
        <a href="/films/watched">Watched</a>
        <a href="/films/towatch">To Watch</a>
      </div>
      <div class="timeline">
        <p class="timeline__flat-count">{books.length} books</p>
        {books.map((item) => (
          <div class="timeline__item">
            <span class="timeline__title">{item.title}</span>
            <span class="timeline__creator">{item.author}</span>
          </div>
        ))}
      </div>
    </div>
  </main>
</Base>
