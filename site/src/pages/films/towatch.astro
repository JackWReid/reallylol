---
import Base from "../../layouts/Base.astro";
import SubNav from "../../components/SubNav.astro";
import { FilmTable } from "../../components/PaginatedList";
import { getFilms } from "../../lib/cms-data";

const films = await getFilms("towatch") as Array<{
  name: string;
  year: string;
  date_updated: string;
}>;
---

<Base title="To Watch" section="films">
  <main class="single-main single-main--films">
    <SubNav section="films" />
    <h1 class="single-main__title">To Watch</h1>
    <FilmTable films={films} showDate={false} client:load />
  </main>
</Base>
