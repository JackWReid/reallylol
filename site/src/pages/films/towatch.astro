---
import Base from "../../layouts/Base.astro";
import filmsData from "../../data/films-towatch.json";

interface FilmRow { name: string; year: string | null; date_updated: string; }
const films = (filmsData as FilmRow[]).sort((a, b) => a.name.localeCompare(b.name));
---

<Base title="Library" section="library">
  <main>
    <div class="library">
      <div class="section-tabs">
        <a href="/books/read">Read</a>
        <a href="/books/reading">Reading</a>
        <a href="/books/toread">To Read</a>
        <span class="tab-divider" />
        <a href="/films/watched">Watched</a>
        <a href="/films/towatch" class="active">To Watch</a>
      </div>
      <div class="timeline">
        <p class="timeline__flat-count">{films.length} films</p>
        {films.map((item) => (
          <div class="timeline__item">
            <span class="timeline__title">{item.name}</span>
            {item.year && <span class="timeline__creator">({item.year})</span>}
          </div>
        ))}
      </div>
    </div>
  </main>
</Base>
