---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Pagination from "../../../components/Pagination.astro";
import { getPrettyName, tagToSlug } from "../../../lib/tags";
import { generateSummary } from "../../../lib/summary";
import { r2Thumb } from "../../../lib/images";

interface TagItem {
  type: "blog" | "photo" | "highlight";
  title: string;
  date: Date;
  slug: string;
  excerpt?: string;
  image?: string;
}

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog");
  const photos = await getCollection("photo");
  const highlights = await getCollection("highlight");

  const tagItems = new Map<string, TagItem[]>();

  for (const p of posts) {
    for (const tag of p.data.tags ?? []) {
      if (!tagItems.has(tag)) tagItems.set(tag, []);
      tagItems.get(tag)!.push({
        type: "blog",
        title: p.data.title,
        date: p.data.date,
        slug: p.id,
        excerpt: generateSummary(p.body ?? ""),
      });
    }
  }

  for (const p of photos) {
    for (const tag of p.data.tags ?? []) {
      if (!tagItems.has(tag)) tagItems.set(tag, []);
      tagItems.get(tag)!.push({
        type: "photo",
        title: p.data.title,
        date: p.data.date,
        slug: p.id,
        image: p.data.image,
      });
    }
  }

  for (const h of highlights) {
    for (const tag of h.data.tags ?? []) {
      if (!tagItems.has(tag)) tagItems.set(tag, []);
      tagItems.get(tag)!.push({
        type: "highlight",
        title: h.data.title,
        date: h.data.date,
        slug: h.id,
      });
    }
  }

  return Array.from(tagItems.entries()).flatMap(([tag, items]) => {
    const sorted = items.sort((a, b) => b.date.getTime() - a.date.getTime());
    return paginate(sorted, {
      params: { tag: tagToSlug(tag) },
      props: { tag },
      pageSize: 40,
    });
  });
}) satisfies GetStaticPaths;

const { tag } = Astro.props;
const { page } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function itemUrl(type: string, slug: string): string {
  if (type === "blog") return `/post/${slug}/`;
  if (type === "photo") return `/photo/${slug}/`;
  if (type === "highlight") return `/highlight/${slug}/`;
  return "#";
}
---

<Base title={`#${getPrettyName(tag)}`}>
  <main class="tag-archive">
    <h1>#{getPrettyName(tag)}</h1>
    <p class="tag-archive__count">{page.total} items</p>
    <div class="tag-archive__list">
      {page.data.map((item) => (
        <a href={itemUrl(item.type, item.slug)} class="feed-item">
          <div class="feed-item__text">
            <span class="feed-item__title">{item.title}</span>
            <span class="feed-meta">
              {item.type} · {formatDate(item.date)}
            </span>
          </div>
          {item.image && (
            <div class="feed-item__thumb">
              <img src={r2Thumb(item.image)} alt="" loading="lazy" />
            </div>
          )}
        </a>
      ))}
    </div>
    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </main>
</Base>
