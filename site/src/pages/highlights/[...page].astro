---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Pagination from "../../components/Pagination.astro";
import { tagToSlug } from "../../lib/tags";

export const getStaticPaths = (async ({ paginate }) => {
  const highlights = await getCollection("highlight");
  const sorted = highlights.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
  return paginate(sorted, { pageSize: 40 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function getDomain(url: string): string {
  try {
    return new URL(url).hostname.replace("www.", "");
  } catch {
    return "";
  }
}
---

<Base title="Highlights" section="links" currentPage={page.currentPage} lastPage={page.lastPage}>
  <main class="highlights-list">
    <h1>Highlights</h1>
    {page.data.map((h) => (
      <article class="links-highlights__item">
        <a href={`/highlight/${h.id.replace(/\.md$/, "")}/`} class="links-highlights__title">{h.data.title}</a>
        <div class="links-saved__meta">
          {h.data.link && (
            <a href={h.data.link} target="_blank" rel="noopener">{getDomain(h.data.link)}</a>
          )}
          <span class="links-saved__date">{formatDate(h.data.date)}</span>
          {h.data.tags && h.data.tags.map((tag: string) => (
            <a href={`/tags/${tagToSlug(tag)}/`}>#{tag}</a>
          ))}
        </div>
      </article>
    ))}
    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </main>
</Base>
