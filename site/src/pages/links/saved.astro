---
import Base from "../../layouts/Base.astro";
import linksData from "../../data/links.json";

interface LinkRow { title: string; url: string; date: string; excerpt: string | null; cover: string | null; tags: string[]; }
const links = (linksData as LinkRow[]).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function getDomain(url: string): string {
  try { return new URL(url).hostname.replace("www.", ""); }
  catch { return ""; }
}
---

<Base title="Links" section="links">
  <main>
    <div class="links-page">
      <div class="section-tabs">
        <a href="/links/saved" class="active">Saved</a>
        <a href="/links/highlights">Highlights</a>
        <a href="/links/blogroll">Blogroll</a>
      </div>
      <div class="links-saved">
        {links.map((link) => (
          <div class="links-saved__item">
            <div class="links-saved__header">
              <a href={link.url} target="_blank" rel="noopener" class="links-saved__title">{link.title}</a>
              <span class="links-saved__domain">{getDomain(link.url)}</span>
            </div>
            <div class="links-saved__meta">
              {link.tags?.map((tag) => <span>#{tag}</span>)}
              <span class="links-saved__date">{formatDate(link.date)}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Base>
