---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { LinksPage } from "../../components/LinksList";
import { getLinks } from "../../lib/cms-data";

const savedLinks = await getLinks();
const saved = (savedLinks as Array<{ title: string; url: string; date: string; tags?: string[] }>)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const highlights = await getCollection("highlight");
const sortedHighlights = highlights
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((h) => ({
    title: h.data.title,
    slug: h.id,
    date: h.data.date.toISOString(),
    link: h.data.link,
    excerpt: h.body?.slice(0, 300)?.replace(/[#*_\[\]>]/g, "").trim(),
  }));

// Blogroll: parse markdown links from the CMS blogroll page
const blogrollPage = await getCollection("page").then(
  (pages) => pages.find((p) => p.id === "blogroll")
);
const blogroll: Array<{ title: string; url: string; description?: string; section?: string }> = [];
if (blogrollPage?.body) {
  let currentSection = "";
  for (const line of blogrollPage.body.split("\n")) {
    const sectionMatch = line.match(/^###\s+(.+)/);
    if (sectionMatch) {
      currentSection = sectionMatch[1].trim();
      continue;
    }
    const linkMatch = line.match(/^-\s+\[([^\]]+)\]\(([^)]+)\)(?:\s*-\s*(.+))?/);
    if (linkMatch) {
      blogroll.push({
        title: linkMatch[1],
        url: linkMatch[2],
        description: linkMatch[3]?.trim(),
        section: currentSection || undefined,
      });
    }
  }
}

const data = {
  saved,
  highlights: sortedHighlights,
  blogroll,
};
---

<Base title="Links" section="links">
  <main>
    <LinksPage data={data} client:load />
  </main>
</Base>
