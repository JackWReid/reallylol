---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const highlights = await getCollection("highlight");
const sorted = highlights.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function getDomain(url: string): string {
  try { return new URL(url).hostname.replace("www.", ""); }
  catch { return ""; }
}
---

<Base title="Links" section="links">
  <main>
    <div class="links-page">
      <div class="section-tabs">
        <a href="/links/saved">Saved</a>
        <a href="/links/highlights" class="active">Highlights</a>
        <a href="/links/blogroll">Blogroll</a>
      </div>
      <div class="links-highlights">
        {sorted.map((h) => (
          <div class="links-highlights__item">
            <a href={`/highlight/${h.id}/`} class="links-highlights__title">{h.data.title}</a>
            <div class="links-saved__meta">
              {h.data.link && (
                <a href={h.data.link} target="_blank" rel="noopener">{getDomain(h.data.link)}</a>
              )}
              <span class="links-saved__date">{formatDate(h.data.date)}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Base>
