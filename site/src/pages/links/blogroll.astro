---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

const blogrollPage = await getCollection("page").then(
  (pages) => pages.find((p) => p.id === "blogroll")
);
const { Content } = blogrollPage ? await render(blogrollPage) : { Content: null };
---

<Base title="Links" section="links">
  <main>
    <div class="links-page">
      <div class="section-tabs">
        <a href="/links/saved">Saved</a>
        <a href="/links/highlights">Highlights</a>
        <a href="/links/blogroll" class="active">Blogroll</a>
      </div>
      {Content && (
        <div class="links-blogroll">
          <Content />
        </div>
      )}
    </div>
  </main>
</Base>
