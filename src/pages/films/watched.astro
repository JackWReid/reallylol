---
import Base from "../../layouts/Base.astro";
import SubNav from "../../components/SubNav.astro";
import watchedData from "../../data/films/watched.json";

const films = watchedData as Array<{
  name: string;
  year: string;
  date_updated: string;
}>;
---

<Base title="Watched" section="films">
  <main class="single-main single-main--films">
    <SubNav section="films" />
    <h1 class="single-main__title">Watched</h1>
    <table class="media-table media-table--film">
      <thead>
        <tr>
          <th>Date</th>
          <th>Title</th>
        </tr>
      </thead>
      <tbody>
        {films.map((film) => (
          <tr>
            <td class="media-table__date">{film.date_updated}</td>
            <td class="media-table__title">{film.name} ({film.year})</td>
          </tr>
        ))}
      </tbody>
    </table>
  </main>
</Base>
