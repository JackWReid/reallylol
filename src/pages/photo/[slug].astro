---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Calendar from "../../components/icons/Calendar.astro";
import Location from "../../components/icons/Location.astro";
import TagList from "../../components/TagList.astro";
import { r2Hero } from "../../lib/images";

export async function getStaticPaths() {
  const photos = await getCollection("photo");
  return photos.map((photo) => ({
    params: { slug: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const { Content } = await render(photo);

const dateIso = photo.data.date.toISOString().slice(0, 10);
const heroUrl = r2Hero(photo.data.image);
---

<Base title={photo.data.title} section="photo">
  <main class="single-main">
    <h1 class="single-main__title">{photo.data.title}</h1>

    <p class="single-main__date">
      <Calendar /> <time datetime={dateIso}>{dateIso}</time>
    </p>

    {photo.data.location && (
      <p class="single-main__location">
        <Location />
        <span>{photo.data.location}</span>
      </p>
    )}

    {photo.data.tags && photo.data.tags.length > 0 && (
      <div class="single-main__tags">
        <TagList tags={photo.data.tags} />
      </div>
    )}

    <div class="single-main__photo">
      <img src={heroUrl} alt={photo.data.title} />
    </div>

    <div class="single-main__content">
      <Content />
    </div>
  </main>
</Base>
