{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["bun-types", "@cloudflare/workers-types"]
  },
  "include": ["cms/**/*.ts", "cli/**/*.ts", "shared/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "site", "dist"]
}
