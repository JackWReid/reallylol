---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { getPrettyName } from "../../lib/tags";

const posts = await getCollection("post");
const photos = await getCollection("photo");
const highlights = await getCollection("highlight");

const tagCounts = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
for (const photo of photos) {
  for (const tag of photo.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
for (const highlight of highlights) {
  for (const tag of highlight.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Tags">
  <main class="section-main section-main--tags">
    <h1 class="section-title">Tags</h1>
    <ul class="tag-list">
      {sortedTags.map(([tag, count]) => (
        <li class="tag-list__item">
          <a href={`/tags/${tag}/`}>
            #{getPrettyName(tag).toLowerCase()}
          </a>
          <span class="tag-list__count">({count})</span>
        </li>
      ))}
    </ul>
  </main>
</Base>
