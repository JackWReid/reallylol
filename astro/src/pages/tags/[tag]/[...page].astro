---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Base from "../../../layouts/Base.astro";
import PreviewCard from "../../../components/PreviewCard.astro";
import Pagination from "../../../components/Pagination.astro";
import { getPrettyName, tagToSlug } from "../../../lib/tags";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("post");
  const photos = await getCollection("photo");
  const highlights = await getCollection("highlight");

  // Collect all unique tags
  const allTags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) allTags.add(tag);
  }
  for (const photo of photos) {
    for (const tag of photo.data.tags ?? []) allTags.add(tag);
  }
  for (const highlight of highlights) {
    for (const tag of highlight.data.tags ?? []) allTags.add(tag);
  }

  const paths: ReturnType<typeof paginate>[] = [];

  for (const tag of allTags) {
    const taggedPosts = posts
      .filter((p) => (p.data.tags ?? []).includes(tag))
      .map((p) => ({ type: "post" as const, ...p }));
    const taggedPhotos = photos
      .filter((p) => (p.data.tags ?? []).includes(tag))
      .map((p) => ({ type: "photo" as const, ...p }));
    const taggedHighlights = highlights
      .filter((h) => (h.data.tags ?? []).includes(tag))
      .map((h) => ({ type: "highlight" as const, ...h }));

    const combined = [...taggedPosts, ...taggedPhotos, ...taggedHighlights].sort(
      (a, b) => b.data.date.getTime() - a.data.date.getTime()
    );

    const tagPages = paginate(combined, {
      params: { tag: tagToSlug(tag) },
      props: { tag },
      pageSize: 10,
    });
    paths.push(...tagPages);
  }

  return paths;
}

const { page, tag } = Astro.props;
const prettyTag = getPrettyName(tag);
---

<Base title={`#${prettyTag.toLowerCase()}`}>
  <main class="section-main section-main--tag">
    <h1 class="section-title">#{prettyTag.toLowerCase()}</h1>
    <div class="multi-preview-list">
      {page.data.map((item) => {
        if (item.type === "post") {
          return (
            <PreviewCard
              type="post"
              title={item.data.title}
              date={item.data.date}
              id={item.id}
              tags={item.data.tags}
            />
          );
        }
        if (item.type === "photo") {
          return (
            <PreviewCard
              type="photo"
              title={item.data.title}
              date={item.data.date}
              id={item.id}
              tags={item.data.tags}
              image={item.data.image}
              location={item.data.location}
            />
          );
        }
        if (item.type === "highlight") {
          return (
            <PreviewCard
              type="highlight"
              title={item.data.title}
              date={item.data.date}
              id={item.id}
              tags={item.data.tags}
            />
          );
        }
      })}
    </div>
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
    />
  </main>
</Base>
